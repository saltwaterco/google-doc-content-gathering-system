# Path to the service account JSON key (keep this file OUTSIDE the repo).
GOOGLE_APPLICATION_CREDENTIALS=/Users/you/.config/gdoc-spike/service-account.json

# The Drive folder ID (the XXXX in drive.google.com/drive/folders/XXXX).
DRIVE_FOLDER_ID=

# walk_doc.php captures only content AFTER this marker line (drops the writer-instructions
# preamble). Set to "" to capture the whole doc. Matching is case-insensitive.
CONTENT_START_MARKER=Writing Begins Beneath This Line
